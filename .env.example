TELEGRAM_BOT_TOKEN=
DATABASE_PATH=ais_alerts.sqlite3
DEFAULT_INTERVAL_MINUTES=5
MIN_INTERVAL_MINUTES=1

# If these are empty, the bot asks the user to share Telegram location.
OBSERVER_LAT=
OBSERVER_LON=

# Free option: https://aisstream.io/
AIS_PROVIDER=aisstream
INITIAL_LOOKUP_SECONDS=20
STALE_POSITION_MINUTES=60
STALE_REFRESH_INTERVAL_MINUTES=30
AISSTREAM_API_KEY=
AISSTREAM_WAIT_SECONDS=90

# Google Sheets logging. Create a Google Cloud service account JSON file,
# share the AIS spreadsheet with its client_email, and put the local file path here.
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_OAUTH_CREDENTIALS_FILE=
GOOGLE_OAUTH_TOKEN_FILE=google-sheets-token.json
GOOGLE_SHEET_NAME=AIS
GOOGLE_SPREADSHEET_ID=
GOOGLE_WORKSHEET_NAME=

# MarineTraffic
MARINETRAFFIC_API_KEY=
MARINETRAFFIC_TIMESPAN_MINUTES=1440

# VesselFinder
VESSELFINDER_API_KEY=
VESSELFINDER_INCLUDE_SATELLITE=0
VESSELFINDER_INTERVAL_MINUTES=1440
