TELEGRAM_BOT_TOKEN=
DATABASE_PATH=ais_alerts.sqlite3
DEFAULT_INTERVAL_MINUTES=5
MIN_INTERVAL_MINUTES=1

# If these are empty, the bot asks the user to share Telegram location.
OBSERVER_LAT=
OBSERVER_LON=

# Free option: https://aisstream.io/
AIS_PROVIDER=aisstream
AISSTREAM_API_KEY=
AISSTREAM_WAIT_SECONDS=90

# MarineTraffic
MARINETRAFFIC_API_KEY=
MARINETRAFFIC_TIMESPAN_MINUTES=1440

# VesselFinder
VESSELFINDER_API_KEY=
VESSELFINDER_INCLUDE_SATELLITE=0
VESSELFINDER_INTERVAL_MINUTES=1440
